    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', jsonData.tokens.accessToken);",
                  "pm.collectionVariables.set('refreshToken', jsonData.tokens.refreshToken);",
                  "pm.collectionVariables.set('userId', String(jsonData.user.id));",
                  "",
                  "if (jsonData.emailConfirmation && jsonData.emailConfirmation.confirmationUrl) {",
                  "  var confirmationUrl = new URL(jsonData.emailConfirmation.confirmationUrl);",
                  "  pm.collectionVariables.set('emailConfirmationToken', confirmationUrl.searchParams.get('token'));",
                  "}",
                  "",
                  "pm.test('Registered user has an id', function () {",
                  "  pm.expect(jsonData.user.id).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"name\": \"Sofia Student\",\n  \"password\": \"{{userPassword}}\",\n  \"confirmPassword\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Registers a regular user and stores accessToken, refreshToken, userId, and email confirmation token."
          },
          "response": []
        },
